# Copy this file to .env and fill in your values
# .env is gitignored and will never be committed

FIREFLIES_API_KEY=
ANTHROPIC_API_KEY=
MONDAY_API_TOKEN=

# Paste the full service account JSON (one line) — see SETUP.md
GOOGLE_SERVICE_ACCOUNT_JSON=

# Optional: a secret token Make.com will send in the webhook header
WEBHOOK_SECRET=
